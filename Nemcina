<!DOCTYPE html>
<html lang="cs">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, standalone=yes">
<title>Stavba Němčina</title>
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Stavba DE">
<meta name="theme-color" content="#F5C500">
<link rel="manifest" href="manifest.json">
<style>
  @import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;800&family=Barlow:wght@400;500;600&display=swap');

  :root {
    --yellow: #F5C500;
    --yellow-dark: #D4A900;
    --black: #1A1A1A;
    --concrete: #3D3D3D;
    --concrete-light: #5C5C5C;
    --dust: #B8B0A0;
    --dust-light: #EAE6DF;
    --white: #F7F5F2;
    --red: #C0392B;
    --green: #27AE60;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: 'Barlow', sans-serif;
    min-height: 100vh;
    padding: 0 0 40px 0;
  }

  /* HEADER */
  header {
    background: var(--yellow);
    padding: 14px 20px 12px;
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 4px solid var(--black);
  }
  .header-icon { font-size: 28px; }
  header h1 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 22px;
    color: var(--black);
    text-transform: uppercase;
    letter-spacing: 1px;
    line-height: 1.1;
  }
  header h1 span {
    display: block;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 2px;
    opacity: 0.7;
  }

  /* STATS BAR */
  .stats-bar {
    background: var(--concrete);
    padding: 10px 20px;
    display: flex;
    gap: 20px;
    align-items: center;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    border-bottom: 2px solid var(--black);
  }
  .stat { display: flex; align-items: center; gap: 6px; }
  .stat-dot { width: 10px; height: 10px; border-radius: 50%; }
  .dot-total { background: var(--dust); }
  .dot-known { background: var(--green); }
  .dot-unknown { background: var(--red); }
  .progress-bar {
    flex: 1;
    height: 6px;
    background: var(--black);
    border-radius: 3px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: var(--green);
    border-radius: 3px;
    transition: width 0.4s ease;
  }

  /* CATEGORY FILTER */
  .categories {
    padding: 14px 16px 0;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .cat-btn {
    background: var(--concrete);
    border: 2px solid var(--concrete-light);
    color: var(--dust-light);
    padding: 6px 14px;
    border-radius: 3px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: all 0.15s;
  }
  .cat-btn.active {
    background: var(--yellow);
    border-color: var(--yellow);
    color: var(--black);
  }
  .cat-btn:hover:not(.active) {
    border-color: var(--yellow);
    color: var(--yellow);
  }

  /* CARD AREA */
  .card-area {
    padding: 20px 16px 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .card-counter {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--dust);
    margin-bottom: 12px;
  }

  /* THE CARD */
  .card-wrapper {
    width: 100%;
    max-width: 420px;
    perspective: 1200px;
    height: 240px;
    cursor: pointer;
  }

  .card {
    width: 100%;
    height: 100%;
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .card.flipped { transform: rotateY(180deg); }

  .card-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    border-radius: 6px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 24px;
    text-align: center;
  }

  /* FRONT */
  .card-front {
    background: var(--concrete);
    border: 3px solid var(--concrete-light);
    border-top: 6px solid var(--yellow);
  }
  .card-emoji { font-size: 52px; margin-bottom: 10px; line-height: 1; }
  .card-cs {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 32px;
    font-weight: 800;
    color: var(--white);
    text-transform: uppercase;
    letter-spacing: 1px;
    line-height: 1;
  }
  .card-category-tag {
    margin-top: 10px;
    background: var(--black);
    color: var(--dust);
    font-size: 11px;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 2px;
  }
  .tap-hint {
    position: absolute;
    bottom: 12px;
    right: 14px;
    font-size: 11px;
    color: var(--dust);
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 600;
    letter-spacing: 1px;
    opacity: 0.6;
  }

  /* BACK */
  .card-back {
    background: var(--yellow);
    border: 3px solid var(--yellow-dark);
    border-top: 6px solid var(--black);
    transform: rotateY(180deg);
  }
  .card-de {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 36px;
    font-weight: 800;
    color: var(--black);
    text-transform: uppercase;
    letter-spacing: 1px;
    line-height: 1;
    margin-bottom: 6px;
  }
  .card-article {
    font-size: 14px;
    font-weight: 600;
    color: var(--concrete);
    margin-bottom: 4px;
    font-family: 'Barlow Condensed', sans-serif;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .card-pronunciation {
    font-size: 18px;
    color: var(--concrete);
    font-style: italic;
    margin-bottom: 6px;
  }
  .card-plural {
    font-size: 13px;
    color: var(--concrete-light);
    font-family: 'Barlow Condensed', sans-serif;
    letter-spacing: 0.5px;
  }

  /* BUTTONS */
  .card-buttons {
    display: flex;
    gap: 12px;
    margin-top: 18px;
    width: 100%;
    max-width: 420px;
  }
  .btn {
    flex: 1;
    padding: 14px;
    border: none;
    border-radius: 4px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 16px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }
  .btn-unknown {
    background: var(--concrete);
    color: var(--white);
    border: 2px solid var(--red);
  }
  .btn-unknown:hover { background: var(--red); }
  .btn-known {
    background: var(--yellow);
    color: var(--black);
    border: 2px solid var(--yellow-dark);
  }
  .btn-known:hover { background: var(--yellow-dark); }

  .nav-buttons {
    display: flex;
    gap: 10px;
    margin-top: 12px;
    width: 100%;
    max-width: 420px;
  }
  .btn-nav {
    flex: 1;
    padding: 10px;
    background: transparent;
    border: 2px solid var(--concrete-light);
    color: var(--dust);
    border-radius: 4px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all 0.15s;
  }
  .btn-nav:hover { border-color: var(--yellow); color: var(--yellow); }
  .btn-nav:disabled { opacity: 0.3; cursor: not-allowed; }

  .btn-reset {
    width: 100%;
    max-width: 420px;
    padding: 12px;
    background: transparent;
    border: 2px solid var(--concrete-light);
    color: var(--dust);
    border-radius: 4px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    margin-top: 10px;
    transition: all 0.15s;
  }
  .btn-reset:hover { border-color: var(--dust); color: var(--white); }

  /* FINISHED */
  .finished {
    text-align: center;
    padding: 40px 20px;
    max-width: 420px;
    margin: 0 auto;
  }
  .finished-icon { font-size: 60px; margin-bottom: 16px; }
  .finished h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 32px;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--yellow);
    margin-bottom: 8px;
  }
  .finished p { color: var(--dust); line-height: 1.6; }

  /* WORD LIST */
  .word-list-section {
    padding: 24px 16px 0;
    max-width: 860px;
    margin: 0 auto;
  }
  .word-list-section h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 18px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--dust);
    border-bottom: 2px solid var(--concrete);
    padding-bottom: 8px;
    margin-bottom: 14px;
  }
  .word-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 8px;
  }
  .word-tile {
    background: var(--concrete);
    border: 2px solid var(--concrete-light);
    border-radius: 4px;
    padding: 10px 12px;
    cursor: pointer;
    transition: all 0.15s;
    position: relative;
  }
  .word-tile:hover { border-color: var(--yellow); }
  .word-tile.known { border-color: var(--green); }
  .word-tile.unknown { border-color: var(--red); }
  .word-tile .wt-cs {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: var(--white);
  }
  .word-tile .wt-de {
    font-size: 12px;
    color: var(--dust);
    margin-top: 2px;
  }
  .word-tile .wt-badge {
    position: absolute;
    top: 6px;
    right: 6px;
    font-size: 12px;
  }

  .btn-speak {
    margin-top: 12px;
    background: var(--black);
    border: 2px solid var(--concrete-light);
    color: var(--white);
    padding: 8px 20px;
    border-radius: 4px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 15px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all 0.15s;
  }
  .btn-speak:hover { border-color: var(--yellow); color: var(--yellow); }
</style>
</head>
<body>

<header>
  <div class="header-icon">⛏️</div>
  <h1>
    <span>Němčina pro stavbu</span>
    Výkopy & Stavební práce
  </h1>
</header>

<div class="stats-bar">
  <div class="stat"><div class="stat-dot dot-total"></div><span id="stat-total">0</span> slov</div>
  <div class="stat"><div class="stat-dot dot-known"></div><span id="stat-known">0</span> umím</div>
  <div class="stat"><div class="stat-dot dot-unknown"></div><span id="stat-unknown">0</span> učím se</div>
  <div class="progress-bar"><div class="progress-fill" id="progress-fill" style="width:0%"></div></div>
</div>

<div class="categories" id="categories"></div>

<div class="card-area" id="card-area">
  <div class="card-counter" id="card-counter"></div>
  <div class="card-wrapper" id="card-wrapper" onclick="flipCard()">
    <div class="card" id="card">
      <div class="card-face card-front" id="card-front"></div>
      <div class="card-face card-back" id="card-back"></div>
    </div>
  </div>
  <div class="card-buttons" id="card-buttons" style="display:none">
    <button class="btn btn-unknown" onclick="markCard(false)">✗ Nevím</button>
    <button class="btn btn-known" onclick="markCard(true)">✓ Umím</button>
  </div>
  <div class="nav-buttons">
    <button class="btn-nav" id="btn-prev" onclick="prevCard()">← Předchozí</button>
    <button class="btn-nav" id="btn-next" onclick="nextCard()">Další →</button>
  </div>
  <button class="btn-reset" onclick="resetAll()">↺ Začít znovu</button>
</div>

<div class="word-list-section">
  <h2>🗂 Všechna slova</h2>
  <div class="word-grid" id="word-grid"></div>
</div>

