  { cs: "Výstražný kužel", de: "der Absperrkegel", art: "der · Absperrkegel", pron: "[abšpérkégel]", emoji: "🔺", cat: "Bezpečnost" },
  { cs: "Zábrana", de: "die Absperrung", art: "die · Absperrungen", pron: "[abšpérung]", emoji: "🚧", cat: "Bezpečnost" },
  { cs: "Výstražná páska", de: "das Absperrband", art: "das · Absperrbänder", pron: "[abšpérbant]", emoji: "⛔", cat: "Bezpečnost" },
  { cs: "Bezpečnostní boty", de: "die Sicherheitsschuhe", art: "die (pl.)", pron: "[zicherhajtšúe]", emoji: "👢", cat: "Bezpečnost" },

  // STAVBA
  { cs: "Základ", de: "das Fundament", art: "das · Fundamente", pron: "[fundament]", emoji: "🏗️", cat: "Stavba" },
  { cs: "Zeď", de: "die Mauer", art: "die · Mauern", pron: "[mauer]", emoji: "🧱", cat: "Stavba" },
  { cs: "Lešení", de: "das Gerüst", art: "das · Gerüste", pron: "[gerüst]", emoji: "🏗️", cat: "Stavba" },
  { cs: "Plán stavby", de: "der Bauplan", art: "der · Baupläne", pron: "[bauplan]", emoji: "📋", cat: "Stavba" },
  { cs: "Staveniště", de: "die Baustelle", art: "die · Baustellen", pron: "[bauštele]", emoji: "🚧", cat: "Stavba" },
  { cs: "Stavbyvedoucí", de: "der Bauleiter", art: "der · Bauleiter", pron: "[baulajter]", emoji: "👷", cat: "Stavba" },
  { cs: "Jeřáb", de: "der Kran", art: "der · Kräne", pron: "[krán]", emoji: "🏗️", cat: "Stavba" },
];

let currentDeck = [];
let currentIndex = 0;
let isFlipped = false;
let knownCards = new Set();
let unknownCards = new Set();
let activeCategory = "Vše";

const categories = ["Vše", ...new Set(vocabulary.map(v => v.cat))];

function speak(text) {
  if (!window.speechSynthesis) return;
  window.speechSynthesis.cancel();
  const u = new SpeechSynthesisUtterance(text);
  u.lang = 'de-DE';
  u.rate = 0.85;
  window.speechSynthesis.speak(u);
}

function init() {
  // Build category buttons
  const catEl = document.getElementById('categories');
  catEl.innerHTML = categories.map(c =>
    `<button class="cat-btn ${c === activeCategory ? 'active' : ''}" onclick="setCategory('${c}')">${c}</button>`
  ).join('');
  filterDeck();
  renderWordGrid();
}

function setCategory(cat) {
  activeCategory = cat;
  document.querySelectorAll('.cat-btn').forEach(b => b.classList.toggle('active', b.textContent === cat));
  filterDeck();
}

function filterDeck() {
  currentDeck = activeCategory === "Vše" ? [...vocabulary] : vocabulary.filter(v => v.cat === activeCategory);
  currentIndex = 0;
  isFlipped = false;
  showCard();
  updateStats();
}

function showCard() {
  if (currentIndex >= currentDeck.length) {
    showFinished(); return;
  }
  const w = currentDeck[currentIndex];
  const card = document.getElementById('card');
  card.classList.remove('flipped');
  isFlipped = false;

  document.getElementById('card-front').innerHTML = `
    <div class="card-emoji">${w.emoji}</div>
    <div class="card-cs">${w.cs}</div>
    <div class="card-category-tag">${w.cat}</div>
    <div class="tap-hint">KLEPNI PRO PŘEKLAD</div>
  `;
  document.getElementById('card-back').innerHTML = `
    <div class="card-article">${w.art}</div>
    <div class="card-de">${w.de.replace(/^(der|die|das)\s/,'')}</div>
    <div class="card-pronunciation">${w.pron}</div>
    <div class="card-plural">${w.art}</div>
    <button class="btn-speak" onclick="event.stopPropagation(); speak(this.dataset.word)" data-word="${w.de}">🔊 Přehrát</button>
  `;

  document.getElementById('card-counter').textContent = `${currentIndex + 1} / ${currentDeck.length}`;
  document.getElementById('card-buttons').style.display = 'none';
  document.getElementById('card-area').style.display = 'flex';
  document.getElementById('card-wrapper').style.display = 'block';

  document.getElementById('btn-prev').disabled = currentIndex === 0;
  document.getElementById('btn-next').disabled = currentIndex >= currentDeck.length - 1;
}

function flipCard() {
  const card = document.getElementById('card');
  isFlipped = !isFlipped;
  card.classList.toggle('flipped', isFlipped);
  document.getElementById('card-buttons').style.display = isFlipped ? 'flex' : 'none';
}

function markCard(known) {
  const word = currentDeck[currentIndex];
  if (known) { knownCards.add(word.cs); unknownCards.delete(word.cs); }
  else { unknownCards.add(word.cs); knownCards.delete(word.cs); }
  updateStats();
  renderWordGrid();
  nextCard();
}

function nextCard() {
  if (currentIndex < currentDeck.length - 1) {
    currentIndex++;
    isFlipped = false;
    showCard();
  }
}

function prevCard() {
  if (currentIndex > 0) {
    currentIndex--;
    isFlipped = false;
    showCard();
  }
}

function resetAll() {
  knownCards.clear();
  unknownCards.clear();
  currentIndex = 0;
  isFlipped = false;
  showCard();
  updateStats();
  renderWordGrid();
}

function showFinished() {
  const area = document.getElementById('card-area');
  area.innerHTML = `
    <div class="finished">
      <div class="finished-icon">🎉</div>
      <h2>Hotovo!</h2>
      <p>Prošel jsi všechny kartičky.<br>Umíš <strong>${knownCards.size}</strong> z ${currentDeck.length} slov.</p>
      <br>
      <button class="btn-reset" onclick="resetAll(); init()">↺ Opakovat znovu</button>
    </div>
  `;
}

function updateStats() {
  document.getElementById('stat-total').textContent = vocabulary.length;
  document.getElementById('stat-known').textContent = knownCards.size;
  document.getElementById('stat-unknown').textContent = unknownCards.size;
  const pct = vocabulary.length > 0 ? (knownCards.size / vocabulary.length * 100) : 0;
  document.getElementById('progress-fill').style.width = pct + '%';
}

function renderWordGrid() {
  const grid = document.getElementById('word-grid');
  grid.innerHTML = vocabulary.map(w => {
    const cls = knownCards.has(w.cs) ? 'known' : unknownCards.has(w.cs) ? 'unknown' : '';
    const badge = knownCards.has(w.cs) ? '✅' : unknownCards.has(w.cs) ? '❌' : '';
    return `<div class="word-tile ${cls}" onclick="jumpTo('${w.cs}')">
      <div class="wt-cs">${w.emoji} ${w.cs}</div>
      <div class="wt-de">${w.de}</div>
      <div class="wt-badge">${badge}</div>
    </div>`;
  }).join('');
}

function jumpTo(cs) {
  const idx = vocabulary.findIndex(v => v.cs === cs);
  if (idx === -1) return;
  activeCategory = "Vše";
  document.querySelectorAll('.cat-btn').forEach(b => b.classList.toggle('active', b.textContent === "Vše"));
  filterDeck();
  currentIndex = idx;
  isFlipped = false;
  showCard();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

init();
</script>
</body>
</html>
